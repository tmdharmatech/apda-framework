{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Artefato Pedagógico Digital Aberto",
  "type": "object",
  "required": [
    "tipo_artefato",
    "origem",
    "conteudo_pedagogico",
    "metadados_processamento",
    "validacao_humana"
  ],
  "properties": {
    "tipo_artefato": {
      "type": "string",
      "enum": [
        "diario_aee",
        "estudo_de_caso",
        "plano_atendimento",
        "relatorio_pedagogico",
        "atividade_adaptada",
        "outro"
      ]
    },
    "origem": {
      "type": "object",
      "required": ["nome_arquivo", "formato_original"],
      "properties": {
        "nome_arquivo": { "type": "string" },
        "formato_original": { "type": "string" },
        "pagina_ou_aba": { "type": ["string", "null"] },
        "segmento_indice": { "type": ["integer", "null"] },
        "segmento_total": { "type": ["integer", "null"] }
      }
    },
    "conteudo_pedagogico": {
      "type": "object",
      "properties": {
        "objetivo_pedagogico": { "type": ["string", "null"] },
        "barreiras_identificadas": {
          "type": "array",
          "items": { "type": "string" }
        },
        "estrategias_pedagogicas": {
          "type": "array",
          "items": { "type": "string" }
        },
        "recursos_acessibilidade": {
          "type": "array",
          "items": { "type": "string" }
        },
        "observacoes_relevantes": { "type": ["string", "null"] }
      }
    },
    "anonimizacao": {
      "type": "object",
      "properties": {
        "aplicada": { "type": "boolean" },
        "itens_mascarados": {
          "type": "array",
          "items": { "type": "string" }
        },
        "risco_reidentificacao": {
          "type": "string",
          "enum": ["baixo", "medio", "alto", "nao_avaliado"]
        }
      }
    },
    "metadados_processamento": {
      "type": "object",
      "required": ["pipeline_versao", "data_processamento", "status"],
      "properties": {
        "pipeline_versao": { "type": "string" },
        "data_processamento": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["processado", "erro", "pendente_revisao"]
        },
        "confianca_extracao": {
          "type": "string",
          "enum": ["baixa", "media", "alta", "nao_calculada"]
        }
      }
    },
    "validacao_humana": {
      "type": "object",
      "required": ["necessaria", "status"],
      "properties": {
        "necessaria": { "type": "boolean" },
        "status": {
          "type": "string",
          "enum": ["pendente", "validado", "rejeitado"]
        },
        "responsavel": { "type": ["string", "null"] }
      }
    }
  }
}
