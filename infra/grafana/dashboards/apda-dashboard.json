{
  "__inputs": [],
  "__elements": {},
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Dashboard principal do APDA Framework — qualidade, privacidade e desempenho",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "type": "stat",
      "title": "Artefatos Processados (total)",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "blue", "value": null },
            { "color": "green", "value": 10 }
          ]},
          "unit": "short"
        }
      },
      "targets": [{
        "expr": "sum(apda_artefatos_processados_total)",
        "legendFormat": "Total"
      }]
    },

    {
      "type": "stat",
      "title": "Taxa de JSON Válido (%)",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "green", "value": 90 }
          ]},
          "unit": "percent",
          "min": 0, "max": 100
        }
      },
      "targets": [{
        "expr": "100 * sum(rate(apda_json_valido_total[5m])) / sum(rate(apda_artefatos_processados_total[5m]))",
        "legendFormat": "JSON válido"
      }]
    },

    {
      "type": "stat",
      "title": "Alertas de PII Detectados",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 1 },
            { "color": "red", "value": 5 }
          ]},
          "unit": "short"
        }
      },
      "targets": [{
        "expr": "sum(increase(apda_vazamento_pii_total[1h]))",
        "legendFormat": "PII (última hora)"
      }]
    },

    {
      "type": "stat",
      "title": "Latência Mediana (p50)",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 10 },
            { "color": "red", "value": 30 }
          ]},
          "unit": "s"
        }
      },
      "targets": [{
        "expr": "histogram_quantile(0.50, sum(rate(apda_tempo_processamento_segundos_bucket[5m])) by (le))",
        "legendFormat": "p50"
      }]
    },

    {
      "type": "stat",
      "title": "Custo Total (Sabiá API)",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center" },
      "fieldConfig": {
        "defaults": { "unit": "currencyBRL" }
      },
      "targets": [{
        "expr": "sum(litellm_spend_metric{model=~\"sabia.*\"})",
        "legendFormat": "Custo Sabiá"
      }]
    },

    {
      "type": "timeseries",
      "title": "Pipelines por Workflow (últimas 6h)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (workflow) (rate(apda_pipeline_execucoes_total{status=\"ok\"}[5m]))",
          "legendFormat": "{{ workflow }}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Taxa JSON Válido por Modelo",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (modelo) (rate(apda_json_valido_total[5m])) / sum by (modelo) (rate(apda_artefatos_processados_total[5m]))",
          "legendFormat": "{{ modelo }}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Latência do Pipeline (p50 / p95 / p99)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(apda_pipeline_tempo_segundos_bucket{status=\"ok\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(apda_pipeline_tempo_segundos_bucket{status=\"ok\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(apda_pipeline_tempo_segundos_bucket{status=\"ok\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },

    {
      "type": "barchart",
      "title": "Campos Inventados por Tipo de Artefato",
      "description": "Métrica de alucinação — campos gerados sem correspondência no documento fonte",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      },
      "targets": [{
        "expr": "sum by (tipo_artefato) (increase(apda_campos_inventados_total[1h]))",
        "legendFormat": "{{ tipo_artefato }}"
      }]
    },

    {
      "type": "timeseries",
      "title": "Tokens por Segundo — llama-server local",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "expr": "llama_tokens_per_second{job=\"llama-3b\"}",
          "legendFormat": "3B"
        },
        {
          "expr": "llama_tokens_per_second{job=\"llama-1b\"}",
          "legendFormat": "1B"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Alertas de PII por Tipo (últimas 6h)",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      },
      "targets": [{
        "expr": "sum by (tipo_pii) (increase(apda_vazamento_pii_total[5m]))",
        "legendFormat": "{{ tipo_pii }}"
      }]
    },

    {
      "type": "gauge",
      "title": "Revisões Humanas Pendentes",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 26 },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "min": 0, "max": 500,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 200 }
          ]}
        }
      },
      "targets": [{
        "expr": "apda_revisoes_pendentes",
        "legendFormat": "Pendentes"
      }]
    },

    {
      "type": "gauge",
      "title": "Taxa de Aprovação Humana (%)",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 26 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 60 },
            { "color": "green", "value": 80 }
          ]}
        }
      },
      "targets": [{
        "expr": "100 * sum(apda_aprovados_revisao_humana_total) / sum(apda_revisoes_concluidas_total)",
        "legendFormat": "Aprovação"
      }]
    },

    {
      "type": "timeseries",
      "title": "Comparação: Modelo Base vs Fine-tuned",
      "description": "Evolução da taxa de JSON válido antes e depois do fine-tuning",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 26 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(apda_json_valido_total{modelo=~\".*base.*\"}[5m])) / sum(rate(apda_artefatos_processados_total{modelo=~\".*base.*\"}[5m]))",
          "legendFormat": "Modelo base"
        },
        {
          "expr": "sum(rate(apda_json_valido_total{modelo=~\".*finetuned.*\"}[5m])) / sum(rate(apda_artefatos_processados_total{modelo=~\".*finetuned.*\"}[5m]))",
          "legendFormat": "Fine-tuned"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Tempo por Step (p95)",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 32 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, step) (rate(apda_step_tempo_segundos_bucket{status=\"ok\"}[5m])))",
          "legendFormat": "{{ step }}"
        }
      ]
    },

    {
      "type": "barchart",
      "title": "I/O por Step (última hora)",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 32 },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "expr": "sum by (step, direction) (increase(apda_step_io_bytes_sum[1h]))",
          "legendFormat": "{{ step }} {{ direction }}"
        }
      ]
    }

  ],

  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["apda", "educação", "ia"],
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "America/Bahia",
  "title": "APDA Framework — Monitor",
  "uid": "apda-main-dashboard",
  "version": 1
}
