# APDA Framework — Variáveis de ambiente
#
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
#
# O arquivo .env NÃO deve ser versionado (já está no .gitignore).

# ── LiteLLM Proxy ─────────────────────────────────────────────────────────────
# Chave mestra usada para autenticação no proxy LiteLLM.
# Gere uma chave aleatória segura: openssl rand -hex 32
LITELLM_MASTER_KEY=mude-esta-chave

# ── Grafana ───────────────────────────────────────────────────────────────────
# Senha do usuário admin do Grafana.
GRAFANA_ADMIN_PASSWORD=mude-esta-senha

# ── Maritaca / Sabiá ──────────────────────────────────────────────────────────
# API key do serviço Maritaca (necessária para workflows com o modelo Sabiá).
# Obtenha em: https://plataforma.maritaca.ai
MARITACA_API_KEY=

# ── llama-server (opcional) ───────────────────────────────────────────────────
# URL base do llama-server local. Padrão: http://127.0.0.1:8091
# APDA_LLAMA_BASE_URL=http://127.0.0.1:8091

# ── LiteLLM URL (opcional) ────────────────────────────────────────────────────
# URL do proxy LiteLLM. Padrão: http://127.0.0.1:4000
# APDA_LITELLM_URL=http://127.0.0.1:4000

# ── Métricas (opcional) ───────────────────────────────────────────────────────
# URL do exportador de métricas APDA. Padrão: http://127.0.0.1:8000/push
# APDA_METRICS_URL=http://127.0.0.1:8000/push

# ── Modo LiteLLM (opcional) ───────────────────────────────────────────────────
# Defina como "1" para forçar roteamento via LiteLLM em todos os scripts Python.
# APDA_LITELLM=1
